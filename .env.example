# =============================================================================
# Just Tap Super Admin API — Environment Configuration
# Copy to .env:  cp .env.example .env
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# --- MySQL ---
# Local (native Node): DB_HOST=localhost
# Docker Compose:      DB_HOST=mysql  (set automatically in docker-compose.yml)
DB_HOST=localhost
DB_PORT=3306
DB_USER=justtap
DB_PASSWORD=justtap_secret
DB_NAME=justtap
MYSQL_ROOT_PASSWORD=root_secret
# Root credentials for migrations (Docker / fresh install). Optional locally if DB_USER is root.
DB_MIGRATE_USER=root
DB_MIGRATE_PASSWORD=root_secret

# --- Redis ---
# Local: redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
# Set SKIP_REDIS=true to run without Redis (readiness will fail Redis check)
# SKIP_REDIS=true

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# --- Auth / OTP ---
OTP_EXPIRES_MINUTES=10
PASSWORD_RESET_EXPIRES_MINUTES=60

# --- Uploads ---
UPLOAD_MAX_FILE_SIZE_MB=5

# --- Docker entrypoint (auto migrate/seed on container start) ---
RUN_MIGRATIONS=true
RUN_SEEDERS=true

# --- Service wait (Docker entrypoint) ---
WAIT_MAX_ATTEMPTS=60
WAIT_INTERVAL_MS=2000
