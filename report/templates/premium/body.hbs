{{!-- Cover Page --}}
<section class="page cover-page">
  <div class="premium-frame"></div>
  {{#if images.backgroundImage}}
    <div class="page-bg" style="background-image:url('{{images.backgroundImage}}')"></div>
  {{/if}}
  <div class="page-content cover-content">
    {{#if images.logo}}
      <img class="cover-logo" src="{{images.logo}}" alt="Logo" />
    {{/if}}
    <p class="cover-eyebrow">Premium Wedding Menu</p>
    <h1 class="cover-title">{{coupleName}}</h1>
    {{#if eventDate}}<p class="cover-date">{{eventDate}}</p>{{/if}}
    {{#if venueName}}<p class="cover-venue">{{venueName}}{{#if cityName}}, {{cityName}}{{/if}}</p>{{/if}}
    {{#if images.heroImage}}
      <div class="hero-image cover-hero">
        <img src="{{images.heroImage}}" alt="Hero" />
      </div>
    {{/if}}
    {{#if packageName}}
      <div class="cover-package gold-border">{{packageName}}</div>
    {{/if}}
  </div>
</section>

{{!-- Couple Photos --}}
{{#if images.brideImage}}
<section class="page couple-page">
  <div class="premium-frame"></div>
  <div class="page-content">
    <h2 class="section-title">The Couple</h2>
    <div class="couple-grid">
      <div class="couple-photo bride">
        <img src="{{images.brideImage}}" alt="{{brideName}}" />
        {{#if brideName}}<p class="photo-caption">{{brideName}}</p>{{/if}}
      </div>
      {{#if images.groomImage}}
      <div class="couple-photo groom">
        <img src="{{images.groomImage}}" alt="{{groomName}}" />
        {{#if groomName}}<p class="photo-caption">{{groomName}}</p>{{/if}}
      </div>
      {{/if}}
    </div>
  </div>
</section>
{{/if}}

{{!-- Gallery --}}
{{#if hasGallery}}
<section class="page gallery-page">
  <div class="premium-frame"></div>
  <div class="page-content">
    <h2 class="section-title">Gallery</h2>
    <div class="gallery-grid">
      {{#each images.gallery}}
        <div class="gallery-item"><img src="{{this}}" alt="Gallery" /></div>
      {{/each}}
    </div>
  </div>
</section>
{{/if}}

{{!-- Menu Sections --}}
{{#if hasMenu}}
  {{#each menuSections}}
<section class="page menu-page">
  <div class="premium-frame"></div>
  <div class="page-content">
    <h2 class="section-title">{{title}}</h2>
    <hr class="gold-line" />
    <div class="menu-grid">
      {{#each items}}
        <article class="menu-item">
          <h3 class="menu-item-name">
            {{#if isVeg}}<span class="veg-badge"></span>{{else}}<span class="non-veg-badge"></span>{{/if}}
            {{name}}
          </h3>
          {{#if description}}<p class="menu-item-desc">{{description}}</p>{{/if}}
        </article>
      {{/each}}
    </div>
  </div>
</section>
  {{/each}}
{{/if}}
